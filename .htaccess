# Disable directory browsing
Options -Indexes

# Custom 404 Error Document
ErrorDocument 404 /404.php

# Enable Rewrite Engine
RewriteEngine On

# Rewrite rule to remove file extensions and map to .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Rewrite rule to remove file extensions and map to .php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Prevent modification of .html and .php extensions from URLs (optional)
# RewriteCond %{THE_REQUEST} \.html?\s [NC]
# RewriteRule ^ - [R=404,L]
# RewriteCond %{THE_REQUEST} \.php\s [NC]
# RewriteRule ^ - [R=404,L]

# Set caching headers for fonts, images, and videos
<FilesMatch "\.(woff|woff2|ttf|otf|svg|eot|jpg|jpeg|png|gif|ico|webp|mp4|webm)$">
    Header set Cache-Control "max-age=31536000, public"
</FilesMatch>

# Set caching headers for HTML, CSS, and JS files
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=3600, public"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</IfModule>

# Enable Gzip compression for faster loading
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# Ensure correct MIME types for images and fonts
<IfModule mod_mime.c>
    AddType image/jpeg .jpg .jpeg
    AddType image/png .png
    AddType image/gif .gif
    AddType image/webp .webp
    AddType image/svg+xml .svg
    AddType application/font-woff2 .woff2
    AddType application/font-woff .woff
</IfModule>

# Use HTTP/2 if available
<IfModule mod_http2.c>
    Protocols h2 http/1.1
</IfModule>

# Security: Prevent access to hidden files like .htaccess
<FilesMatch "^\.">
    Order Allow,Deny
    Deny from all
</FilesMatch>
